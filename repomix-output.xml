                        "cpu_utilization": stmt.excluded.cpu_utilization,
                        "database_connections": stmt.excluded.database_connections,
                        "free_storage_space": stmt.excluded.free_storage_space,
                        "data_transfer": stmt.excluded.data_transfer,
                    }
