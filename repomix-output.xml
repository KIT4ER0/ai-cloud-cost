    confidence: 0.95

  # ---------- Data Transfer ----------
  DT_CROSS_AZ_WASTE:
    enabled: true
    network_cross_az_gb_30d_gt: 100 # มีทราฟฟิกชิ่งข้าม AZ เยอะเกิน 100GB ใน 30 วัน (เช็กจากยอด EC2 network_cross_az_gb)
