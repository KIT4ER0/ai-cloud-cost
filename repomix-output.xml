    autocorr = [np.corrcoef(data[:-i], data[i:])[0,1] for i in range(1, max_period)]
    peaks, _ = signal.find_peaks(autocorr, height=0.3)
    return peaks[0] if len(peaks) > 0 else 7  # Default to weekly
