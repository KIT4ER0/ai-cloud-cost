    recommendation: "review_cdn_or_caching" # แนะนำให้ใช้งาน CloudFront/CDN เข้ามาครอบเพื่อทำแคชชิ่ง ลดค่าแบนด์วิดท์มหาศาล
    confidence: 0.80

  # ---------- Load Balancer (ALB) ----------
