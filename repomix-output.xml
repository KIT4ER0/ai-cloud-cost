}

// Mock Data Quality
export const mockDataQuality: DataQuality = {
    lastUpdated: new Date('2026-02-07T08:30:00'),
    dataCoverage: 92,
    confidenceScore: 'high',
    dataPoints: 2760,
}

// Mock Service Breakdown (Top 5)
