        return "exponential_smoothing"
    elif has_seasonality:
        return "seasonal_naive"
    elif volatility_level in ["high", "moderate"]:
        return "linear_trend"
    else:
        return "ensemble"  # Default for stable data
```

#### 5. Adaptive MAPE Threshold
