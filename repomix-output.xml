```python
def categorize_costs(service, resource_info, daily_costs):
    breakdown = {
        "compute": [],      # Instance/Lambda compute costs
        "storage": [],      # EBS/RDS/S3 storage costs
        "network": [],      # Data transfer costs
        "requests": [],     # API/operation costs
