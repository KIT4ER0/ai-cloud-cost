    recommendation: "fix_target_group_errors" # แจ้งให้รีบซ่อมเซิร์ฟเวอร์หลังบ้าน
    confidence: 0.90

  CLB_MIGRATE_TO_ALB:
    enabled: true
    lb_type: "CLB"               # ค่าที่เก็บจริงในฐานข้อมูล alb_resources.alb_type
